---
import Base from '../../layouts/Base.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import CTABlock from '../../components/CTABlock.astro';
import { getCollection } from 'astro:content';

const allComparisons = (await getCollection('comparisons', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base
  title="Head-to-Head Comparisons - Field Service Stack"
  description="Side-by-side comparisons of field service management software. See how the top platforms stack up on pricing, features, and real-world performance."
>
  <section class="pt-12 pb-14 md:pt-16 md:pb-20">
    <div class="max-w-[65ch] mb-10">
      <h1 class="rise rise-1 mb-4">Head-to-Head Comparisons</h1>
      <p class="rise rise-3 text-muted text-base md:text-lg leading-relaxed font-body">
        Choosing between two platforms? We break down the differences that actually matter: pricing, scheduling, invoicing, mobile experience, and customer support.
      </p>
    </div>

    {allComparisons.length > 0 ? (
      <div class="reveal grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {allComparisons.map((post) => (
          <ReviewCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            collection="compare"
            category="Comparison"
            rating={post.data.rating}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
          />
        ))}
      </div>
    ) : (
      <p class="text-muted font-body">Comparisons coming soon.</p>
    )}
  </section>

  <!-- CTA -->
  <section class="pb-14 md:pb-20">
    <CTABlock />
  </section>
</Base>
