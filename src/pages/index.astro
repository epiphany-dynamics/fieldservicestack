---
import Base from '../layouts/Base.astro';
import CTABlock from '../components/CTABlock.astro';
import RatingBadge from '../components/RatingBadge.astro';

import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews', ({ data }) => !data.draft);
const allComparisons = await getCollection('comparisons', ({ data }) => !data.draft);
const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const allGear = await getCollection('gear', ({ data }) => !data.draft);

const collectionMap: Record<string, { path: string; label: string }> = {
  reviews: { path: 'reviews', label: 'Review' },
  comparisons: { path: 'compare', label: 'Comparison' },
  guides: { path: 'guides', label: 'Guide' },
  gear: { path: 'gear', label: 'Gear' },
};

const allPosts = [
  ...allReviews.map((p) => ({ ...p, _col: 'reviews' as const })),
  ...allComparisons.map((p) => ({ ...p, _col: 'comparisons' as const })),
  ...allGuides.map((p) => ({ ...p, _col: 'guides' as const })),
  ...allGear.map((p) => ({ ...p, _col: 'gear' as const })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = allPosts[0];
const latest = allPosts.slice(1, 6);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// "Find your stack" matcher — map trades to the guides that cover them
const tradeKeywords: { trade: string; keywords: string[] }[] = [
  { trade: 'HVAC', keywords: ['hvac'] },
  { trade: 'Plumbing', keywords: ['plumbing'] },
  { trade: 'Electrical', keywords: ['electrical', 'electrician'] },
  { trade: 'Landscaping', keywords: ['landscaping'] },
  { trade: 'Lawn Care', keywords: ['lawn-care'] },
  { trade: 'Painting', keywords: ['painting'] },
  { trade: 'Roofing', keywords: ['roofing'] },
  { trade: 'Pest Control', keywords: ['pest-control'] },
  { trade: 'Pool Service', keywords: ['pool-service'] },
  { trade: 'Pressure Washing', keywords: ['pressure-washing'] },
  { trade: 'Septic', keywords: ['septic'] },
  { trade: 'Snow Removal', keywords: ['snow-removal'] },
  { trade: 'Solar', keywords: ['solar'] },
  { trade: 'Tree Service', keywords: ['tree-service'] },
  { trade: 'Garage Door', keywords: ['garage-door'] },
  { trade: 'Carpet Cleaning', keywords: ['carpet-cleaning'] },
  { trade: 'Commercial Cleaning', keywords: ['commercial-cleaning'] },
  { trade: 'Appliance Repair', keywords: ['appliance-repair'] },
  { trade: 'Fencing', keywords: ['fence'] },
  { trade: 'General Contracting', keywords: ['general-contractor'] },
  { trade: 'Handyman', keywords: ['handyman'] },
  { trade: 'Irrigation', keywords: ['irrigation'] },
];

const matcherData = tradeKeywords
  .map(({ trade, keywords }) => ({
    trade,
    guides: allGuides
      .filter((g) => keywords.some((k) => g.id.includes(k)))
      .slice(0, 2)
      .map((g) => ({ title: g.data.title, url: `/guides/${g.id}/` })),
  }))
  .filter((t) => t.guides.length > 0)
  .sort((a, b) => a.trade.localeCompare(b.trade));

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Field Service Stack',
  url: 'https://fieldservicestack.com',
  description: 'Independent software reviews, comparisons, and buyer\'s guides for field service professionals.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://fieldservicestack.com/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Field Service Stack',
  url: 'https://fieldservicestack.com',
  logo: 'https://fieldservicestack.com/images/brand/fss-logo.png',
  description: 'Independent reviews, comparisons, and buyer\'s guides for field service professionals.',
  sameAs: [
    'https://epiphanydynamics.ai',
    'https://www.wikidata.org/wiki/Q139569923',
    'https://github.com/epiphany-dynamics',
    'https://www.linkedin.com/company/epiphanydynamics',
    'https://www.crunchbase.com/organization/epiphanydynamics',
  ],
  parentOrganization: {
    '@type': 'Organization',
    '@id': 'https://www.wikidata.org/wiki/Q139569923',
    name: 'Epiphany Dynamics',
    url: 'https://epiphanydynamics.ai',
  },
};

const categories = [
  {
    title: 'Software Reviews',
    description: 'In-depth, honest reviews of the tools field service businesses actually use.',
    href: '/reviews/',
  },
  {
    title: 'Head-to-Head Comparisons',
    description: 'Side-by-side breakdowns so you can stop guessing and start deciding.',
    href: '/compare/',
  },
  {
    title: "Buyer's Guides",
    description: 'Curated picks by trade. HVAC, plumbing, electrical, landscaping, and more.',
    href: '/guides/',
  },
  {
    title: 'Tools & Gear',
    description: 'Physical tools and equipment reviewed by people who actually use them on job sites.',
    href: '/gear/',
  },
];
---

<Base
  title="Field Service Stack - Software Reviews for Service Businesses"
  description="Independent software reviews, comparisons, and buyer's guides for field service professionals. Find the right tools for your business."
  schema={[webSiteSchema, orgSchema]}
>
  <!-- Hero -->
  <section class="hero pt-14 pb-12 md:pt-24 md:pb-20">
    <p class="meta rise rise-1 mb-6">Independent. Field-tested. No pay-to-play.</p>
    <h1 class="hero-title rise rise-2 mb-6 max-w-[16ch]">Find the Right Software for Your Service Business</h1>
    <p class="rise rise-3 text-muted text-base md:text-lg leading-relaxed font-body max-w-[55ch]">
      Independent reviews, head-to-head comparisons, and buyer's guides written by someone who has actually worked in the field. No affiliate rankings. No pay-to-play. Just honest assessments of the software and gear that field service businesses depend on every day.
    </p>

    <!-- Find your stack -->
    <div class="matcher rise rise-4 mt-10 md:mt-14 border border-border rounded-xl bg-surface p-5 md:p-7">
      <div class="flex flex-wrap items-baseline justify-between gap-2 mb-4">
        <p class="meta">Find your stack</p>
        <p class="meta matcher-status" id="matcher-status" aria-live="polite">Pick a trade</p>
      </div>
      <div class="matcher-chips" id="matcher-chips" role="group" aria-label="Choose your trade">
        {matcherData.map((item, i) => (
          <button type="button" class="mchip" data-index={i}>
            {item.trade}
          </button>
        ))}
      </div>
      <div class="matcher-results" id="matcher-results"></div>
    </div>
    <script type="application/json" id="matcher-data" set:html={JSON.stringify(matcherData)} />
  </section>

  <!-- Featured -->
  {featured && (
    <section class="pb-14 md:pb-20">
      <div class="flex items-baseline justify-between gap-4 mb-6">
        <h2 class="section-heading">Latest</h2>
      </div>

      <a href={`/${collectionMap[featured._col].path}/${featured.id}/`} class="feature-card reveal group grid md:grid-cols-2 border border-border rounded-xl overflow-hidden bg-surface" data-tilt>
        {featured.data.image && (
          <div class="feature-image-wrap relative overflow-hidden">
            <img
              src={featured.data.image}
              alt={featured.data.imageAlt || featured.data.title}
              class="feature-image absolute inset-0 w-full h-full object-cover"
              loading="eager"
            />
          </div>
        )}
        <div class="flex flex-col justify-center p-6 md:p-10">
          <div class="flex items-center gap-4 mb-4">
            <span class="meta">{collectionMap[featured._col].label}</span>
            <span class="meta" aria-hidden="true">/</span>
            <time class="meta" datetime={featured.data.date.toISOString()}>{formatDate(featured.data.date)}</time>
          </div>
          <h3 class="feature-title font-heading font-bold text-white text-2xl md:text-3xl leading-tight mb-3">
            {featured.data.title}
          </h3>
          <p class="text-muted text-sm md:text-base font-body leading-relaxed line-clamp-3 mb-5">
            {featured.data.description}
          </p>
          <div class="flex items-center gap-4 mt-auto">
            {featured.data.rating !== undefined && (
              <RatingBadge rating={featured.data.rating} size="sm" />
            )}
            <span class="feature-more text-sm font-body font-medium text-cream">
              Read the {collectionMap[featured._col].label.toLowerCase()} <span class="feature-arrow" aria-hidden="true">&rarr;</span>
            </span>
          </div>
        </div>
      </a>

      <!-- Latest list -->
      <ul class="mt-4">
        {latest.map((post) => (
          <li class="reveal">
            <a href={`/${collectionMap[post._col].path}/${post.id}/`} class="latest-row group grid grid-cols-[auto_1fr_auto] items-baseline gap-4 md:gap-6 py-4 border-b border-border">
              <time class="meta shrink-0" datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="min-w-0">
                <span class="latest-title block font-heading font-semibold text-white text-base md:text-lg leading-snug">
                  {post.data.title}
                </span>
              </span>
              <span class="meta latest-cat shrink-0 hidden sm:inline">{collectionMap[post._col].label}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Categories -->
  <section class="pb-14 md:pb-20">
    <h2 class="section-heading mb-6">Browse by Category</h2>
    <div class="cat-list border-t border-border">
      {categories.map((cat) => (
        <a href={cat.href} class="cat-row reveal group grid md:grid-cols-[1fr_auto] items-center gap-2 md:gap-8 py-6 md:py-8 border-b border-border">
          <div>
            <h3 class="cat-title font-heading font-bold text-white text-xl md:text-2xl leading-tight mb-1.5">
              {cat.title}
            </h3>
            <p class="text-sm text-muted font-body leading-relaxed max-w-[52ch]">{cat.description}</p>
          </div>
          <span class="cat-arrow" aria-hidden="true">&rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-14 md:pb-20">
    <CTABlock />
  </section>

</Base>

<script>
  // Find your stack — instant trade → guide matching, no page load
  const dataEl = document.getElementById('matcher-data');
  if (dataEl) {
    const matcherData = JSON.parse(dataEl.textContent || '[]');
    const chips = document.querySelectorAll<HTMLButtonElement>('.mchip');
    const results = document.getElementById('matcher-results');
    const status = document.getElementById('matcher-status');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const item = matcherData[Number(chip.dataset.index)];
        if (!item || !results) return;

        chips.forEach((c) => {
          c.classList.remove('active');
          c.setAttribute('aria-pressed', 'false');
        });
        chip.classList.add('active');
        chip.setAttribute('aria-pressed', 'true');

        if (status) status.textContent = item.trade;

        results.innerHTML = `<div class="mresult-wrap">${item.guides
          .map(
            (g: { title: string; url: string }) => `
              <a class="mresult" href="${g.url}">
                <span class="mresult-title">${g.title}</span>
                <span class="mresult-arrow" aria-hidden="true">&rarr;</span>
              </a>`
          )
          .join('')}</div>`;
        results.classList.add('open');
      });
    });
  }
</script>

<style>
  .hero-title {
    font-size: clamp(2.5rem, 7vw, 4.75rem);
    letter-spacing: -0.025em;
    line-height: 1.02;
  }

  .section-heading {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
  }

  /* === Find your stack matcher === */
  .matcher {
    transition: border-color 0.3s var(--ease-out-expo);
  }
  .matcher:focus-within,
  .matcher:hover {
    border-color: var(--color-border-strong);
  }
  .matcher-status {
    color: var(--color-accent);
  }

  .matcher-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .mchip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    background: var(--color-dark);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    transition:
      color 0.2s var(--ease-out-quart),
      border-color 0.2s var(--ease-out-quart),
      background-color 0.2s var(--ease-out-quart),
      transform 0.25s var(--ease-out-expo);
  }
  .mchip:hover {
    color: var(--color-cream);
    border-color: var(--color-border-strong);
    transform: translateY(-1px);
  }
  .mchip.active {
    color: #050505;
    background: var(--color-accent);
    border-color: var(--color-accent);
    font-weight: 600;
  }

  .matcher-results {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s var(--ease-out-expo);
  }
  .matcher-results.open {
    grid-template-rows: 1fr;
    margin-top: 1.25rem;
  }
  .matcher-results > :global(.mresult-wrap) {
    overflow: hidden;
    min-height: 0;
  }
  .matcher-results :global(.mresult) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--color-border);
    animation: rise-in 0.5s var(--ease-out-expo) both;
  }
  .matcher-results :global(.mresult:nth-child(2)) {
    animation-delay: 0.08s;
  }
  .matcher-results :global(.mresult-title) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--color-cream);
    line-height: 1.3;
    transition: color 0.2s var(--ease-out-quart);
  }
  .matcher-results :global(.mresult:hover .mresult-title) {
    color: var(--color-accent);
  }
  .matcher-results :global(.mresult-arrow) {
    color: var(--color-muted);
    transition:
      transform 0.25s var(--ease-out-expo),
      color 0.25s var(--ease-out-quart);
  }
  .matcher-results :global(.mresult:hover .mresult-arrow) {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  /* Featured card */
  .feature-card {
    position: relative;
    transition:
      border-color 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo),
      transform 0.3s var(--ease-out-expo);
  }
  .feature-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(320px circle at var(--mx, 50%) var(--my, 50%), rgba(242, 182, 50, 0.08), transparent 65%);
    opacity: 0;
    transition: opacity 0.35s var(--ease-out-quart);
    pointer-events: none;
  }
  .feature-card:hover {
    border-color: var(--color-border-strong);
    background-color: var(--color-raised);
  }
  .feature-card:hover::after {
    opacity: 1;
  }
  .feature-image-wrap {
    min-height: 240px;
  }
  .feature-image {
    transition: transform 0.6s var(--ease-out-expo);
  }
  .feature-card:hover .feature-image {
    transform: scale(1.03);
  }
  .feature-title {
    transition: color 0.2s var(--ease-out-quart);
  }
  .feature-card:hover .feature-title {
    color: var(--color-accent);
  }
  .feature-arrow {
    display: inline-block;
    transition: transform 0.25s var(--ease-out-expo);
  }
  .feature-card:hover .feature-arrow {
    transform: translateX(4px);
  }

  /* Latest rows */
  .latest-row {
    transition: border-color 0.2s var(--ease-out-quart);
  }
  .latest-title {
    transition: color 0.2s var(--ease-out-quart);
  }
  .latest-row:hover {
    border-color: var(--color-border-strong);
  }
  .latest-row:hover .latest-title {
    color: var(--color-accent);
  }

  /* Category rows */
  .cat-row {
    transition: border-color 0.2s var(--ease-out-quart);
  }
  .cat-title {
    transition: color 0.2s var(--ease-out-quart);
  }
  .cat-row:hover {
    border-color: var(--color-border-strong);
  }
  .cat-row:hover .cat-title {
    color: var(--color-accent);
  }
  .cat-arrow {
    font-size: 1.375rem;
    color: var(--color-muted);
    transition:
      transform 0.3s var(--ease-out-expo),
      color 0.3s var(--ease-out-quart);
  }
  .cat-row:hover .cat-arrow {
    transform: translateX(6px);
    color: var(--color-accent);
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
