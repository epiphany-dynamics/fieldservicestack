---
---

<div class="newsletter-form bg-surface border border-border rounded-xl p-6 md:p-8">
  <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-2">
    Get Field Service Tips Weekly
  </h3>
  <p class="text-muted font-body text-sm md:text-base mb-6 max-w-[50ch]">
    Software reviews, tool recommendations, and automation tips for service businesses.
  </p>

  <form action="/api/newsletter" method="POST" class="flex flex-col sm:flex-row gap-3">
    <label for="newsletter-email" class="sr-only">Email address</label>
    <input
      type="email"
      id="newsletter-email"
      name="email"
      required
      placeholder="you@company.com"
      autocomplete="email"
      class="flex-1 bg-dark border border-border rounded-full px-5 py-3 text-cream font-body text-sm placeholder:text-cream-faint focus:outline-none focus:border-accent transition-colors"
    />
    <button
      type="submit"
      class="submit-btn shrink-0 bg-cream text-dark font-body font-semibold text-sm px-6 py-3 rounded-full cursor-pointer"
    >
      Subscribe
    </button>
  </form>

  <p class="meta mt-4">
    No spam. Unsubscribe anytime.
  </p>
</div>

<style>
  .submit-btn {
    transition:
      transform 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo);
  }
  .submit-btn:hover {
    transform: translateY(-2px);
    background-color: var(--color-accent);
  }
  .submit-btn:active {
    transform: translateY(0);
  }
</style>
