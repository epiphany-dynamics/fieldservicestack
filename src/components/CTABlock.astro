---
interface Props {
  heading?: string;
  body?: string;
  ctaUrl?: string;
  ctaText?: string;
}

const {
  heading = 'Need Help Automating Your Field Service Business?',
  body = 'We help field service companies find and implement the right software stack. Book a free 30-minute AI workflow review and we will identify at least 3 things you can automate, ranked by impact.',
  ctaUrl = 'https://epiphanydynamics.ai/book',
  ctaText = 'Book a Free AI Workflow Review',
} = Astro.props;
---

<div class="cta-block bg-cream rounded-[1.5rem] p-8 md:p-10 mt-12 relative overflow-hidden">
  <!-- Subtle decorative gradient (Guardian-style ambient glow) -->
  <div class="cta-glow"></div>

  <h3 class="font-heading font-bold text-2xl md:text-3xl mb-4 leading-tight relative z-10" style="color: #050505;">
    {heading}
  </h3>

  <p class="font-body text-base md:text-lg mb-6 max-w-[55ch] leading-relaxed relative z-10" style="color: rgba(5, 5, 5, 0.75);">
    {body}
  </p>

  <a
    href={ctaUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="cta-button inline-block bg-dark font-body font-semibold text-sm md:text-base px-8 py-3 rounded-[12rem] relative z-10"
    style="color: #f0efeb;"
  >
    {ctaText}
  </a>
</div>

<style>
  .cta-glow {
    position: absolute;
    top: -40%;
    right: -10%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(161, 161, 170, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-button {
    color: #f0efeb !important;
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.25);
  }
  .cta-button:active {
    transform: translateY(0);
  }
</style>
