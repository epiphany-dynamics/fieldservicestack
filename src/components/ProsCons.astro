---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 my-6">
  <!-- Pros -->
  <div class="pc-panel bg-surface rounded-xl border border-border overflow-hidden">
    <div class="pc-head pc-head--pros flex items-center gap-2.5 px-6 py-4 border-b border-border">
      <span class="text-positive shrink-0" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8.5l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <h4 class="font-heading font-bold text-white text-lg">Pros</h4>
    </div>
    <ul class="space-y-3 p-6">
      {pros.map((pro) => (
        <li class="flex items-start gap-3 text-cream font-body text-sm leading-relaxed">
          <span class="text-positive mt-1 shrink-0" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8.5l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Cons -->
  <div class="pc-panel bg-surface rounded-xl border border-border overflow-hidden">
    <div class="pc-head pc-head--cons flex items-center gap-2.5 px-6 py-4 border-b border-border">
      <span class="text-negative shrink-0" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </span>
      <h4 class="font-heading font-bold text-white text-lg">Cons</h4>
    </div>
    <ul class="space-y-3 p-6">
      {cons.map((con) => (
        <li class="flex items-start gap-3 text-cream font-body text-sm leading-relaxed">
          <span class="text-negative mt-1 shrink-0" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .pc-head--pros {
    background: rgba(52, 209, 123, 0.06);
  }
  .pc-head--cons {
    background: rgba(242, 97, 77, 0.06);
  }
</style>
