---
const pathname = Astro.url.pathname;

const tabs = [
  { label: 'Home', href: '/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Compare', href: '/compare/' },
  { label: 'Guides', href: '/guides/' },
  { label: 'Gear', href: '/gear/' },
  { label: 'About', href: '/about/' },
];

const externalLinks = [
  { label: 'AI Automation', href: 'https://epiphanydynamics.ai' },
];

const shopUrl = 'https://shop.fieldservicestack.com';

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="mb-4 md:mb-6">
  <div class="frame border border-border">
    <div class="flex items-stretch">
      <!-- Logo -->
      <a
        href="/"
        class="logo-link shrink-0 flex items-center px-2 md:px-3 py-2 border-r border-border"
        aria-label="Field Service Stack home"
      >
        <img
          src="/images/brand/fss-full-logo.png"
          alt="Field Service Stack"
          width="1254"
          height="1254"
          class="brand-lockup"
          decoding="async"
        />
      </a>

      <!-- Tab Navigation (Guardian-style horizontal tabs) -->
      <nav class="flex overflow-x-auto scrollbar-hide" aria-label="Main navigation">
        {tabs.map((tab) => (
          <a
            href={tab.href}
            class:list={[
              'tab-link shrink-0 flex items-center px-4 md:px-5 py-3 text-sm font-body font-medium tracking-wide border-r border-border',
              isActive(tab.href)
                ? 'active'
                : '',
            ]}
            aria-current={isActive(tab.href) ? 'page' : undefined}
          >
            {tab.label}
          </a>
        ))}

        <a
          href={shopUrl}
          class="shop-link shrink-0 flex items-center gap-1.5 px-4 md:px-5 py-3 text-sm font-body font-semibold tracking-wide border-r border-border"
          aria-label="Shop Field Service Stack gear"
        >
          Shop
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 7h12l-1 13H7L6 7Z" />
            <path d="M9 9V5a3 3 0 0 1 6 0v4" />
          </svg>
        </a>

        <!-- External: AI Automation -->
        {externalLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="external-link shrink-0 flex items-center gap-1.5 px-4 md:px-5 py-3 text-sm font-body font-medium tracking-wide border-r border-border"
          >
            {link.label}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Logo hover */
  .logo-link {
    transition: background-color 0.2s cubic-bezier(0.2, 0.21, 0, 1);
  }
  .logo-link:hover {
    background-color: rgba(255, 255, 255, 0.03);
  }
  .brand-lockup {
    display: block;
    width: clamp(5.25rem, 8vw, 7rem);
    height: auto;
  }

  /* Tab links — Guardian-style hover with border-top reveal */
  .tab-link {
    color: #a1a1aa;
    border-top: 3px solid transparent;
    padding-top: 5px;
    transition:
      color 0.2s cubic-bezier(0.2, 0.21, 0, 1),
      border-color 0.2s cubic-bezier(0.2, 0.21, 0, 1),
      background-color 0.2s cubic-bezier(0.2, 0.21, 0, 1);
  }
  .tab-link:hover {
    color: #f0efeb;
    border-top-color: #f0efeb;
    padding-top: 2px; /* Shift up to accommodate border without layout jump */
    background-color: rgba(255, 255, 255, 0.03);
  }

  /* Active state */
  .tab-link.active {
    color: #ffffff;
    border-top-color: #f0efeb;
    padding-top: 2px;
  }

  .shop-link {
    color: #f0efeb;
    border-top: 3px solid #22c55e;
    padding-top: 2px;
    background-color: rgba(34, 197, 94, 0.06);
    transition:
      color 0.2s cubic-bezier(0.2, 0.21, 0, 1),
      background-color 0.2s cubic-bezier(0.2, 0.21, 0, 1);
  }
  .shop-link:hover {
    color: #ffffff;
    background-color: rgba(34, 197, 94, 0.13);
  }
  .shop-link svg {
    opacity: 0.75;
  }

  /* External link — neutral, subtle distinction */
  .external-link {
    color: #a1a1aa;
    border-top: 3px solid transparent;
    padding-top: 5px;
    transition:
      color 0.2s cubic-bezier(0.2, 0.21, 0, 1),
      border-color 0.2s cubic-bezier(0.2, 0.21, 0, 1),
      background-color 0.2s cubic-bezier(0.2, 0.21, 0, 1);
  }
  .external-link:hover {
    color: #a78bfa;
    border-top-color: #a78bfa;
    padding-top: 2px;
    background-color: rgba(167, 139, 250, 0.04);
  }
  .external-link svg {
    opacity: 0.5;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .external-link:hover svg {
    opacity: 0.85;
    transform: translate(1px, -1px);
  }
</style>
