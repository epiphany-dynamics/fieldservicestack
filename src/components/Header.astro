---
const pathname = Astro.url.pathname;

const tabs = [
  { label: 'Home', href: '/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Compare', href: '/compare/' },
  { label: 'Guides', href: '/guides/' },
  { label: 'Gear', href: '/gear/' },
  { label: 'About', href: '/about/' },
];

const externalLinks = [
  { label: 'AI Automation', href: 'https://epiphanydynamics.ai' },
];

const shopUrl = 'https://shop.fieldservicestack.com';

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header sticky top-0 z-40 border-b border-border">
  <div class="shell">
    <div class="flex items-center gap-4 md:gap-8 h-16">
      <!-- Logo -->
      <a
        href="/"
        class="logo-link shrink-0 flex items-center -ml-1.5 px-1.5 py-1 rounded-md"
        aria-label="Field Service Stack home"
      >
        <img
          src="/images/brand/fss-full-logo.png"
          alt="Field Service Stack"
          width="1254"
          height="1254"
          class="brand-lockup"
          decoding="async"
        />
      </a>

      <!-- Primary navigation -->
      <nav class="nav-scroll flex-1 flex items-center gap-1 overflow-x-auto h-full" aria-label="Main navigation">
        {tabs.map((tab) => (
          <a
            href={tab.href}
            class:list={[
              'tab-link relative shrink-0 flex items-center h-full px-3 text-sm font-body',
              isActive(tab.href) ? 'active' : '',
            ]}
            aria-current={isActive(tab.href) ? 'page' : undefined}
          >
            {tab.label}
          </a>
        ))}

        <!-- External: AI Automation -->
        {externalLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="external-link shrink-0 hidden md:flex items-center gap-1.5 h-full px-3 text-sm font-body"
          >
            {link.label}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </a>
        ))}
      </nav>

      <!-- Search + Shop -->
      <button
        type="button"
        class="search-trigger shrink-0 inline-flex items-center gap-2 rounded-full border border-border px-3.5 py-1.5 text-sm text-muted"
        data-search-trigger
        data-magnetic
        aria-label="Search (Command K)"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <kbd class="search-kbd hidden md:inline">⌘K</kbd>
      </button>

      <a
        href={shopUrl}
        class="shop-link shrink-0 inline-flex items-center gap-2 rounded-full border border-border-strong px-4 py-1.5 text-sm font-body font-medium text-cream"
        data-magnetic
        aria-label="Shop Field Service Stack gear"
      >
        Shop
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 7h12l-1 13H7L6 7Z" />
          <path d="M9 9V5a3 3 0 0 1 6 0v4" />
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: rgba(5, 5, 5, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-scroll {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .brand-lockup {
    display: block;
    width: clamp(4.5rem, 7vw, 5.75rem);
    height: auto;
  }

  /* Tab links — hairline indicator under the active item, accent on hover */
  .tab-link {
    color: var(--color-muted);
    font-weight: 400;
    transition: color 0.2s var(--ease-out-quart);
  }
  .tab-link::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: -1px;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out-expo);
  }
  .tab-link:hover {
    color: var(--color-cream);
  }
  .tab-link:hover::after {
    transform: scaleX(1);
  }
  .tab-link.active {
    color: #ffffff;
    font-weight: 500;
  }
  .tab-link.active::after {
    transform: scaleX(1);
  }

  /* External link — quiet, mono-flavored */
  .external-link {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s var(--ease-out-quart);
  }
  .external-link:hover {
    color: var(--color-accent);
  }
  .external-link svg {
    opacity: 0.6;
    transition: opacity 0.2s var(--ease-out-quart), transform 0.25s var(--ease-out-expo);
  }
  .external-link:hover svg {
    opacity: 1;
    transform: translate(1px, -1px);
  }

  /* Search trigger */
  .search-trigger {
    background: transparent;
    cursor: pointer;
    transition:
      color 0.2s var(--ease-out-quart),
      border-color 0.2s var(--ease-out-quart),
      transform 0.3s var(--ease-out-expo);
  }
  .search-trigger:hover {
    color: var(--color-cream);
    border-color: var(--color-border-strong);
  }
  .search-kbd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }

  /* Shop — outline pill, fills on hover. No permanent highlight. */
  .shop-link {
    transition:
      background-color 0.25s var(--ease-out-expo),
      border-color 0.25s var(--ease-out-expo),
      color 0.25s var(--ease-out-expo);
  }
  .shop-link:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #050505;
  }
</style>
