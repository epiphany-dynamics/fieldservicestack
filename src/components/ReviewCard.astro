---
import RatingBadge from './RatingBadge.astro';

interface Props {
  title: string;
  slug: string;
  description: string;
  rating?: number;
  date: Date;
  category: string;
  collection: string;
  image?: string;
  imageAlt?: string;
}

const { title, slug, description, rating, date, category, collection, image, imageAlt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const href = `/${collection}/${slug}/`;
---

<a
  href={href}
  class="review-card group block bg-surface border border-border rounded-xl overflow-hidden"
  data-tilt
>
  <!-- Featured Image -->
  {image ? (
    <div class="card-image-wrap relative overflow-hidden" style="padding-top: 56.25%;">
      <img
        src={image}
        alt={imageAlt || title}
        class="card-image absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      {rating !== undefined && (
        <div class="absolute top-3 right-3 z-10">
          <RatingBadge rating={rating} size="sm" />
        </div>
      )}
    </div>
  ) : (
    <div class="card-image-wrap relative overflow-hidden border-b border-border" style="padding-top: 22%;">
      <div class="absolute inset-0 card-fallback" aria-hidden="true"></div>
      {rating !== undefined && (
        <div class="absolute top-3 right-3 z-10">
          <RatingBadge rating={rating} size="sm" />
        </div>
      )}
    </div>
  )}

  <div class="p-5 md:p-6">
    <!-- Meta row -->
    <div class="flex items-center justify-between gap-3 mb-3">
      <span class="meta card-cat">{category}</span>
      <time class="meta" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </div>

    <!-- Title -->
    <h4 class="card-title font-heading font-bold text-white text-lg leading-snug mb-2">
      {title}
    </h4>

    <!-- Description (2-line clamp) -->
    <p class="text-muted text-sm font-body leading-relaxed line-clamp-2">
      {description}
    </p>
  </div>
</a>

<style>
  .review-card {
    position: relative;
    transition:
      border-color 0.3s var(--ease-out-expo),
      background-color 0.3s var(--ease-out-expo),
      transform 0.3s var(--ease-out-expo);
  }
  .review-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(260px circle at var(--mx, 50%) var(--my, 50%), rgba(242, 182, 50, 0.09), transparent 65%);
    opacity: 0;
    transition: opacity 0.35s var(--ease-out-quart);
    pointer-events: none;
  }
  .review-card:hover {
    border-color: var(--color-border-strong);
    background-color: var(--color-raised);
  }
  .review-card:hover::after {
    opacity: 1;
  }

  .card-fallback {
    background:
      radial-gradient(120% 140% at 20% 0%, rgba(242, 182, 50, 0.07) 0%, transparent 55%),
      linear-gradient(160deg, var(--color-raised) 0%, var(--color-dark) 100%);
  }

  .card-image {
    transition: transform 0.6s var(--ease-out-expo);
  }
  .review-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-title {
    transition: color 0.2s var(--ease-out-quart);
  }
  .review-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-cat {
    transition: color 0.2s var(--ease-out-quart);
  }
  .review-card:hover .card-cat {
    color: var(--color-cream-dim);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
