---
// Spotlight search — Cmd/Ctrl+K, fuzzy over /search.json (built at build time)
---

<div id="search-palette" class="palette" role="dialog" aria-modal="true" aria-label="Search Field Service Stack" aria-hidden="true">
  <div class="palette-backdrop" data-search-close></div>
  <div class="palette-panel">
    <div class="palette-input-row">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="palette-icon">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      <input
        id="palette-input"
        type="text"
        placeholder="Search reviews, comparisons, guides…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search articles"
        aria-expanded="true"
        aria-controls="palette-list"
        role="combobox"
      />
      <kbd class="palette-kbd">esc</kbd>
    </div>
    <ul id="palette-list" class="palette-list" role="listbox" aria-label="Search results"></ul>
    <div class="palette-footer">
      <span><kbd>↑↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script>
  interface SearchItem {
    title: string;
    description: string;
    category: string;
    url: string;
  }

  const palette = document.getElementById('search-palette')!;
  const input = document.getElementById('palette-input') as HTMLInputElement;
  const list = document.getElementById('palette-list')!;

  let items: SearchItem[] | null = null;
  let matches: SearchItem[] = [];
  let activeIndex = -1;
  let lastFocused: Element | null = null;

  function isOpen() {
    return palette.classList.contains('open');
  }

  async function openPalette() {
    if (isOpen()) return;
    lastFocused = document.activeElement;
    palette.classList.add('open');
    palette.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    input.value = '';
    renderIdle();
    // Defer focus past the visibility transition — focusing in the same frame
    // the element flips from visibility:hidden is a no-op in Chromium.
    requestAnimationFrame(() => requestAnimationFrame(() => input.focus()));
    if (!items) {
      try {
        const res = await fetch('/search.json');
        items = await res.json();
        render();
      } catch {
        list.innerHTML = '<li class="palette-empty">Search is unavailable right now.</li>';
      }
    }
  }

  function closePalette() {
    if (!isOpen()) return;
    palette.classList.remove('open');
    palette.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (lastFocused && typeof (lastFocused as HTMLElement).focus === 'function') {
      (lastFocused as HTMLElement).focus();
    }
  }

  function score(item: SearchItem, q: string): number {
    const t = item.title.toLowerCase();
    const d = item.description.toLowerCase();
    const c = item.category.toLowerCase();
    if (t.includes(q)) return 100 - t.indexOf(q);
    if (c.includes(q)) return 60;
    if (d.includes(q)) return 40 - d.indexOf(q) * 0.05;
    // subsequence fallback on the title
    let i = 0;
    for (const ch of t) if (ch === q[i]) i++;
    return i === q.length ? 15 : -1;
  }

  function renderIdle() {
    list.innerHTML = '<li class="palette-empty">Type to search across every review, comparison, and guide.</li>';
    matches = [];
    activeIndex = -1;
  }

  function render() {
    const q = input.value.trim().toLowerCase();
    if (!q || !items) {
      renderIdle();
      return;
    }
    matches = items
      .map((item) => ({ item, s: score(item, q) }))
      .filter((r) => r.s >= 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, 8)
      .map((r) => r.item);
    activeIndex = matches.length > 0 ? 0 : -1;

    if (matches.length === 0) {
      list.innerHTML = `<li class="palette-empty">Nothing found for &ldquo;${escapeHtml(input.value.trim())}&rdquo;.</li>`;
      return;
    }

    list.innerHTML = matches
      .map(
        (m, i) => `
        <li role="option" aria-selected="${i === activeIndex}">
          <a href="${m.url}" class="palette-result ${i === activeIndex ? 'active' : ''}" data-index="${i}">
            <span class="palette-cat">${m.category}</span>
            <span class="palette-title">${escapeHtml(m.title)}</span>
          </a>
        </li>`
      )
      .join('');
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function setActive(next: number) {
    if (matches.length === 0) return;
    activeIndex = (next + matches.length) % matches.length;
    list.querySelectorAll('.palette-result').forEach((el, i) => {
      el.classList.toggle('active', i === activeIndex);
      el.setAttribute('aria-selected', String(i === activeIndex));
      if (i === activeIndex) el.scrollIntoView({ block: 'nearest' });
    });
  }

  input.addEventListener('input', render);

  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(activeIndex + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(activeIndex - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const target = matches[activeIndex];
      if (target) window.location.href = target.url;
    }
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      isOpen() ? closePalette() : openPalette();
    } else if (e.key === 'Escape') {
      closePalette();
    }
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('[data-search-trigger]')) openPalette();
    if (target.closest('[data-search-close]')) closePalette();
  });
</script>

<style>
  .palette {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 18vh 1rem 1rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.25s var(--ease-out-expo),
      visibility 0.25s;
  }
  .palette.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 5, 0.72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .palette-panel {
    position: relative;
    width: 100%;
    max-width: 580px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: 0.875rem;
    overflow: hidden;
    box-shadow: 0 32px 90px rgba(0, 0, 0, 0.6);
    transform: translateY(-10px) scale(0.98);
    transition: transform 0.3s var(--ease-out-expo);
  }
  .palette.open .palette-panel {
    transform: translateY(0) scale(1);
  }

  .palette-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .palette-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }
  #palette-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 1rem;
  }
  #palette-input::placeholder {
    color: var(--color-cream-faint);
  }
  #palette-input:focus-visible {
    outline: none;
  }

  .palette-kbd,
  .palette-footer kbd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    border-radius: 0.3rem;
    padding: 0.15rem 0.4rem;
  }

  .palette-list {
    max-height: 320px;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .palette-list:empty {
    display: none;
  }

  .palette-list :global(.palette-empty) {
    padding: 1.5rem 1rem;
    text-align: center;
    color: var(--color-muted);
    font-size: 0.875rem;
    font-family: var(--font-body);
  }

  .palette-list :global(.palette-result) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.85rem;
    border-radius: 0.55rem;
    transition: background-color 0.15s var(--ease-out-quart);
  }
  .palette-list :global(.palette-result.active) {
    background: var(--color-raised);
  }
  .palette-list :global(.palette-result.active .palette-title) {
    color: var(--color-accent);
  }
  .palette-list :global(.palette-cat) {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .palette-list :global(.palette-title) {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-cream);
    transition: color 0.15s var(--ease-out-quart);
  }

  .palette-footer {
    display: flex;
    gap: 1.25rem;
    padding: 0.7rem 1.25rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .palette {
      padding-top: 10vh;
    }
    .palette-footer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .palette,
    .palette-panel {
      transition: none;
    }
  }
</style>
