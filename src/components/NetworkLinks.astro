---
interface Props {
  links?: { title: string; url: string; site: 'ed' | 'fss' | 'calc' | 'help' | 'hype' }[];
}

const { links } = Astro.props;

if (!links || links.length === 0) return;

const siteLabels: Record<NonNullable<Props['links']>[number]['site'], string> = {
  ed: 'Epiphany Dynamics',
  fss: 'Field Service Stack',
  calc: 'AI for Biz Calculator',
  help: 'Epiphany Learn',
  hype: 'HypeBench',
};
---

<section class="border-t border-border mt-12 pt-10 max-w-[65ch] mx-auto">
  <h2 class="meta mb-5">From our network</h2>
  <ul class="space-y-1">
    {links.slice(0, 4).map((link) => (
      <li>
        <a
          href={link.url}
          class="network-link group flex items-baseline justify-between gap-4 py-2.5 border-b border-border"
          rel="noopener"
        >
          <span class="network-title font-body text-sm md:text-base text-cream">
            {link.title}
          </span>
          <span class="meta shrink-0">{siteLabels[link.site]}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .network-link {
    transition: border-color 0.2s var(--ease-out-quart);
  }
  .network-title {
    transition: color 0.2s var(--ease-out-quart);
  }
  .network-link:hover {
    border-color: var(--color-border-strong);
  }
  .network-link:hover .network-title {
    color: var(--color-accent);
  }
</style>
