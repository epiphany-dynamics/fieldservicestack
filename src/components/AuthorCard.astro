---
interface Props {
  author?: string;
}

const { author = 'Patrick Gibbs' } = Astro.props;

const initials = author
  .split(' ')
  .map((n) => n[0])
  .join('')
  .toUpperCase();
---

<div class="author-card flex items-start gap-5 bg-surface border border-border rounded-xl p-6 md:p-7">
  <!-- Avatar -->
  <div
    class="shrink-0 w-16 h-16 rounded-full bg-dark border border-border-strong flex items-center justify-center"
    aria-hidden="true"
  >
    <span class="font-heading font-bold text-xl" style="color: var(--color-accent);">{initials}</span>
  </div>

  <!-- Bio -->
  <div class="min-w-0">
    <p class="font-heading font-bold text-white text-lg leading-tight">{author}</p>
    <p class="meta mt-1.5">Field Service Technology Expert</p>
    <p class="text-cream-dim text-sm font-body mt-3 leading-relaxed">
      Patrick helps field service businesses find the right software and tools to streamline
      operations. When he's not reviewing software, he's building automation solutions at
      <a
        href="https://epiphanydynamics.ai"
        target="_blank"
        rel="noopener noreferrer"
        class="text-cream underline underline-offset-2 hover:text-white"
      >
        Epiphany Dynamics</a>.
    </p>
    <a
      href="/about/"
      class="author-more inline-flex items-center gap-1.5 text-sm text-muted hover:text-cream font-body mt-4 transition-colors"
    >
      More about {author.split(' ')[0]}
      <span class="author-arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</div>

<style>
  .author-arrow {
    transition: transform 0.25s var(--ease-out-expo);
  }
  .author-more:hover .author-arrow {
    transform: translateX(3px);
  }
</style>
