---
const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Content',
    links: [
      { label: 'Reviews', href: '/reviews/' },
      { label: 'Comparisons', href: '/compare/' },
      { label: "Buyer's Guides", href: '/guides/' },
      { label: 'Tools & Gear', href: '/gear/' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About', href: '/about/' },
      { label: 'Shop FSS gear', href: 'https://shop.fieldservicestack.com' },
      { label: 'AI Automation', href: 'https://epiphanydynamics.ai' },
      { label: 'RSS Feed', href: '/rss.xml' },
    ],
  },
];
---

<footer class="site-footer border-t border-border mt-16 md:mt-24">
  <div class="shell">
    <div class="footer-grid py-12 md:py-16">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" aria-label="Field Service Stack home" class="inline-block">
          <img
            src="/images/brand/fss-full-logo.png"
            alt="Field Service Stack"
            width="1254"
            height="1254"
            class="footer-logo"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-muted text-sm font-body leading-relaxed mt-4 max-w-[32ch]">
          Independent software reviews, comparisons, and buyer's guides for field service professionals.
        </p>
      </div>

      <!-- Link columns -->
      {columns.map((col) => (
        <nav aria-label={`Footer: ${col.heading}`}>
          <p class="meta mb-4">{col.heading}</p>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="footer-link text-sm font-body">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-wrap items-center justify-between gap-4 py-5 border-t border-border text-sm text-muted font-body">
      <span>&copy; {year} Field Service Stack</span>

      <div class="flex items-center gap-4">
        <a
          href="/rss.xml"
          class="rss-link hover:text-cream transition-colors"
          aria-label="RSS Feed"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" />
          </svg>
        </a>

        <a
          href="https://epiphanydynamics.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-cream transition-colors"
        >
          Powered by Epiphany Dynamics
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 740px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .footer-logo {
    display: block;
    width: 6rem;
    height: auto;
  }

  .footer-link {
    color: var(--color-muted);
    transition: color 0.2s var(--ease-out-quart);
  }
  .footer-link:hover {
    color: var(--color-cream);
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
  }
</style>
