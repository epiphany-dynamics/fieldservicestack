---
interface Props {
  rating: number;
  size?: 'sm' | 'lg';
}

const { rating, size = 'lg' } = Astro.props;

const isLarge = size === 'lg';
const dimension = isLarge ? '84px' : '44px';
const fontSize = isLarge ? '1.75rem' : '0.9375rem';
const subSize = isLarge ? '0.7rem' : '0.55rem';

function getColor(r: number): string {
  if (r >= 8) return '#f2b632';
  if (r >= 5) return '#f0efeb';
  return '#f2614d';
}

function getBorderColor(r: number): string {
  if (r >= 8) return 'rgba(242, 182, 50, 0.55)';
  if (r >= 5) return 'rgba(240, 239, 235, 0.22)';
  return 'rgba(242, 97, 77, 0.45)';
}

const color = getColor(rating);
const borderColor = getBorderColor(rating);
---

<div
  class="rating-badge inline-flex flex-col items-center justify-center rounded-full"
  style={`width: ${dimension}; height: ${dimension}; border: 1.5px solid ${borderColor}; background: rgba(5, 5, 5, 0.72); backdrop-filter: blur(6px);`}
  aria-label={`Rating: ${rating} out of 10`}
>
  <span
    class="font-heading font-bold leading-none"
    style={`font-size: ${fontSize}; color: ${color};`}
  >
    {rating % 1 === 0 ? rating.toFixed(1) : rating}
  </span>
  <span
    class="font-mono leading-none"
    style={`font-size: ${subSize}; color: var(--color-muted); letter-spacing: 0.08em;`}
  >
    /10
  </span>
</div>
