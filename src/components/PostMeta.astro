---
interface Props {
  date: string | Date;
  author: string;
  readingTime?: number;
}

const { date, author, readingTime } = Astro.props;

const displayDate =
  typeof date === 'string'
    ? date
    : date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      });
---

<div class="flex flex-wrap items-center gap-x-2 text-sm text-muted font-body">
  <span>{author}</span>
  <span class="text-border-strong" aria-hidden="true">/</span>
  <time>{displayDate}</time>
  {readingTime !== undefined && (
    <>
      <span class="text-border-strong" aria-hidden="true">/</span>
      <span>{readingTime} min read</span>
    </>
  )}
</div>
