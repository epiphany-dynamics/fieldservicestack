---
import Base from './Base.astro';
import PostMeta from '../components/PostMeta.astro';
import RatingBadge from '../components/RatingBadge.astro';
import AuthorCard from '../components/AuthorCard.astro';
import CTABlock from '../components/CTABlock.astro';
import NetworkLinks from '../components/NetworkLinks.astro';
import { extractFAQSchema } from '../lib/faq-schema';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
  rating?: number;
  product?: string;
  image?: string;
  imageAlt?: string;
  author: string;
  focusKeyword: string;
  seoTitle: string;
  rawContent?: string;
  networkLinks?: { title: string; url: string; site: 'ed' | 'fss' | 'calc' | 'help' | 'hype' }[];
}

const {
  title,
  description,
  date,
  updated,
  tags,
  rating,
  product,
  image,
  imageAlt,
  author,
  focusKeyword,
  seoTitle,
  rawContent,
  networkLinks,
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updated
  ? updated.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

// --- Schema.org ---
const pageURL = Astro.url.href;
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const sectionSlug = pathParts[0] ?? 'reviews';
const sectionLabels: Record<string, string> = {
  reviews: 'Reviews',
  compare: 'Comparisons',
  guides: "Buyer's Guides",
  gear: 'Tools & Gear',
};
const sectionLabel = sectionLabels[sectionSlug] ?? 'Articles';
const sectionURL = new URL(`/${sectionSlug}/`, Astro.site).href;

const authorSchema = {
  '@type': 'Person',
  '@id': 'https://www.wikidata.org/wiki/Q139572015',
  name: author,
  sameAs: [
    'https://www.wikidata.org/wiki/Q139572015',
    'https://github.com/patrickg21212',
    'https://www.linkedin.com/in/patrick-gibbs-839b7b237',
  ],
};

const publisher = {
  '@type': 'Organization',
  '@id': 'https://www.wikidata.org/wiki/Q139569923',
  name: 'Epiphany Dynamics',
  url: 'https://epiphanydynamics.ai',
  logo: { '@type': 'ImageObject', url: 'https://epiphanydynamics.ai/images/og-image.png' },
  sameAs: [
    'https://www.wikidata.org/wiki/Q139569923',
    'https://github.com/epiphany-dynamics',
    'https://www.linkedin.com/company/epiphanydynamics',
    'https://www.crunchbase.com/organization/epiphany-dynamics',
    'https://epiphanydynamics.ai',
  ],
};

const articleSchema = rating !== undefined
  ? {
      '@context': 'https://schema.org',
      '@type': 'Review',
      headline: title,
      description,
      author: authorSchema,
      publisher,
      datePublished: date.toISOString().split('T')[0],
      dateModified: (updated ?? date).toISOString().split('T')[0],
      mainEntityOfPage: { '@type': 'WebPage', '@id': pageURL },
      reviewRating: { '@type': 'Rating', ratingValue: rating, bestRating: 10, worstRating: 0 },
      ...(image ? { image: new URL(image, Astro.site).href } : {}),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      author: authorSchema,
      publisher,
      datePublished: date.toISOString().split('T')[0],
      dateModified: (updated ?? date).toISOString().split('T')[0],
      mainEntityOfPage: { '@type': 'WebPage', '@id': pageURL },
      ...(image ? { image: new URL(image, Astro.site).href } : {}),
    };

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://fieldservicestack.com' },
    { '@type': 'ListItem', position: 2, name: sectionLabel, item: sectionURL },
    { '@type': 'ListItem', position: 3, name: title, item: pageURL },
  ],
};

const faqSchema = rawContent ? extractFAQSchema(rawContent) : null;
const schemas = [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---

<Base title={seoTitle} description={description} schema={schemas}>
  <article class="py-8 md:py-12">
    <!-- Post Header -->
    <header class="max-w-[65ch] mx-auto mb-8 md:mb-12 border-b border-border pb-8">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="inline-block text-xs font-medium uppercase tracking-wider text-muted border border-border rounded-[12rem] px-3 py-1 transition-colors hover:text-cream hover:border-border-strong"
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <h1 class="mb-4">{title}</h1>

      {image && (
        <figure class="mt-6 mb-6 -mx-4 md:-mx-8">
          <button
            type="button"
            class="js-zoom group block w-full overflow-hidden rounded-lg"
            style="cursor: zoom-in;"
            data-zoom-src={image}
            aria-label="Enlarge image to read details"
          >
            <img
              src={image}
              alt={imageAlt || title}
              class="w-full h-auto transition-transform duration-500 ease-out group-hover:scale-[1.02]"
              loading="eager"
            />
          </button>
        </figure>
      )}

      {product && (
        <p class="text-muted text-lg mb-4 font-body">{product}</p>
      )}

      <div class="flex flex-wrap items-center gap-4">
        <PostMeta date={formattedDate} author={author} />

        {formattedUpdated && (
          <span class="text-sm text-muted">
            Updated {formattedUpdated}
          </span>
        )}
      </div>

      {rating !== undefined && (
        <div class="mt-6">
          <RatingBadge rating={rating} />
        </div>
      )}
    </header>

    <!-- Article Body -->
    <div class="prose mx-auto">
      <slot />
    </div>

    <!-- Author Card -->
    <footer class="max-w-[65ch] mx-auto mt-12 pt-8 border-t border-border">
      <AuthorCard author={author} />
    </footer>
  </article>

  <NetworkLinks links={networkLinks} />

  <!-- CTA Block -->
  <section class="border-t border-border">
    <CTABlock />
  </section>

  <!-- Image Lightbox: click any post image to read the fine print at full size -->
  <div id="image-lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Enlarged image" aria-hidden="true">
    <button id="lightbox-close" class="lightbox__close" type="button" aria-label="Close image">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <img id="lightbox-img" class="lightbox__img" src="" alt="" />
    <span class="lightbox__hint">Click anywhere or press Esc to close</span>
  </div>
</Base>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    /* tinted toward the site's --color-dark (#050505), not flat black */
    background: rgba(5, 5, 5, 0.94);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    cursor: zoom-out;
    transition: opacity 0.28s cubic-bezier(0.22, 1, 0.36, 1), visibility 0.28s;
  }
  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .lightbox__img {
    max-width: 95vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
    transform: scale(0.96);
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .lightbox.is-open .lightbox__img {
    transform: scale(1);
  }
  .lightbox__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    border: 1px solid rgba(240, 239, 235, 0.22);
    background: rgba(10, 10, 10, 0.6);
    color: #f0efeb;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .lightbox__close:hover {
    border-color: rgba(240, 239, 235, 0.55);
    background: rgba(10, 10, 10, 0.92);
  }
  .lightbox__hint {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: rgba(240, 239, 235, 0.55);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox,
    .lightbox__img {
      transition: none;
    }
  }
</style>

<script>
  function initLightbox() {
    const lightbox = document.getElementById('image-lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    if (!lightbox || !lightboxImg) return;

    let lastFocused = null;

    function open(src, alt) {
      lightboxImg.setAttribute('src', src);
      lightboxImg.setAttribute('alt', alt || '');
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      lastFocused = document.activeElement;
    }

    function close() {
      if (!lightbox.classList.contains('is-open')) return;
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      window.setTimeout(() => {
        if (!lightbox.classList.contains('is-open')) lightboxImg.setAttribute('src', '');
      }, 350);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    // (Re)bind triggers on every init — the post images are page-specific.
    document.querySelectorAll('.js-zoom').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const src = trigger.getAttribute('data-zoom-src');
        const innerImg = trigger.querySelector('img');
        if (src) open(src, innerImg ? innerImg.getAttribute('alt') : '');
      });
    });

    // Bind the overlay/global handlers only once.
    if (!lightbox.dataset.bound) {
      lightbox.dataset.bound = 'true';
      lightbox.addEventListener('click', close); // click anywhere (backdrop, image, X) closes
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    }
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
